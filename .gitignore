# venv
venv/
.venv/
env/

# python cache
__pycache__/
*.py[cod]
*.egg-info/
*.egg

# test / coverage artifacts
.coverage
.coverage.*
.pytest_cache/
htmlcov/

# generated audio output
out/
out_*/
*.wav
*.mp3
*.m4a
*.m4b
*.flac
*.ogg

# but do commit demo audio under samples/
!samples/*.mp3
!samples/*.wav

# personal book files — put your test books in books/ to keep them out of git
books/

# hugging face cache (if someone sets HF_HOME here)
.cache/
models--*/

# IDE / editor
.vscode/
.idea/
*.swp
*.swo

# OS
Thumbs.db
.DS_Store
desktop.ini
